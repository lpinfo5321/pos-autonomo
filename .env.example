# ── BASE DE DATOS (Neon PostgreSQL) ──────────────────────────────────────
# 1. Crea cuenta en https://neon.tech
# 2. Crea un proyecto → copia la "Connection string"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ── AUTENTICACIÓN ─────────────────────────────────────────────────────────
# Genera un secreto aleatorio en: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="tu-secreto-aqui"
# En Vercel cambia esto a tu URL de producción
NEXTAUTH_URL="https://tu-app.vercel.app"

# ── SQUARE (PAGOS CON TARJETA) ────────────────────────────────────────────
# https://developer.squareup.com
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
SQUARE_ENVIRONMENT="sandbox"

# ── VERCEL BLOB (IMÁGENES) ────────────────────────────────────────────────
# Se configura automáticamente al conectar Vercel Blob en el dashboard
BLOB_READ_WRITE_TOKEN=""
